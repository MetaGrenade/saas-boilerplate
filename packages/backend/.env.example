# Server configuration
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Database connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/saas?schema=public"
DATABASE_DIRECT_URL="postgresql://postgres:postgres@localhost:5432/saas?schema=public"

# JWT settings
JWT_ACCESS_TOKEN_SECRET=replace-with-access-secret
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_SECRET=replace-with-refresh-secret
JWT_REFRESH_TOKEN_EXPIRATION=7d

# Cache / queue
REDIS_URL=redis://localhost:6379

# Email delivery (example using SMTP or a third-party provider)
EMAIL_FROM="SaaS Boilerplate <no-reply@example.com>"
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# Stripe billing
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_replace

# OpenAI integrations
OPENAI_API_KEY=sk-openai-replace
OPENAI_ORG_ID=

# Seed defaults (override as needed)
SEED_TENANT_NAME=Acme Inc
SEED_TENANT_SLUG=acme-inc
SEED_ADMIN_NAME=Acme Admin
SEED_ADMIN_EMAIL=admin@acme.inc
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_ROLE=ADMIN
