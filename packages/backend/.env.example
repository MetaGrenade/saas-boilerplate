# Server configuration
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Database connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/saas?schema=public"

# JWT settings
JWT_ACCESS_TOKEN_SECRET=replace-with-access-secret
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_SECRET=replace-with-refresh-secret
JWT_REFRESH_TOKEN_EXPIRATION=7d

# Seed defaults (override as needed)
SEED_TENANT_NAME=Acme Inc
SEED_TENANT_SLUG=acme-inc
SEED_ADMIN_NAME=Acme Admin
SEED_ADMIN_EMAIL=admin@acme.inc
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_ROLE=ADMIN
